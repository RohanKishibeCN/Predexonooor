PREDEXON_API_KEY=pk_xxx
PREDEXON_DATA_API_KEY=
PREDEXON_TRADING_API_KEY=

MODE=live
DRY_RUN=0
ACCOUNT_ID=
# NOTE: if ENABLED_VENUES includes hyperliquid, ACCOUNT_ID is required even in dry_run
# because Router Quote and Trading positions are account-scoped.

STATE_PATH=state.json
POLL_INTERVAL_SECONDS=20
MAX_MARKETS_SCAN=30
REQUEST_INTERVAL_MS=1100
REQUEST_TIMEOUT_MS=20000
REQUEST_MAX_RETRIES=3
OUTCOME_404_TTL_MINUTES=360
MIN_OUTCOME_PRICE=0.05
MAX_OUTCOME_PRICE=0.95

ENABLED_VENUES=polymarket,limitless
VENUE_PREFER_ORDER=polymarket,limitless
# Example for the pm+hl instance:
# ENABLED_VENUES=polymarket,hyperliquid
# VENUE_PREFER_ORDER=polymarket,hyperliquid

MAX_SPREAD=0.02
MIN_TOP_DEPTH_USD=20

STARTING_CAPITAL_USD=100
MAX_PER_TRADE_USD=5
# Hyperliquid market orders require about 10 USDC minimum notional.
# For the pm+hl instance, set MAX_PER_TRADE_USD to >= 10.
MAX_EXPOSURE_PER_MARKET_USD=10
MAX_TOTAL_EXPOSURE_USD=30
MAX_OPEN_POSITIONS=3
DAILY_MAX_LOSS_USD=3
MAX_DRAWDOWN_USD=8

TAKE_PROFIT_PCT=0.01
STOP_LOSS_PCT=0.015
MAX_HOLD_MINUTES=60
SLIPPAGE_GUARD_PCT=0.008
REENTRY_COOLDOWN_SECONDS=0

NOTION_API_TOKEN=
NOTION_DATABASE_ID=
NOTION_VERSION=2022-06-28
